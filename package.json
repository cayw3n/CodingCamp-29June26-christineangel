{
  "name": "todo-life-dashboard",
  "version": "1.0.0",
  "description": "To-do Life Dashboard — single-page vanilla JS web app",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=tests/",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=tests/unit",
    "test:properties": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=tests/properties"
  },
  "devDependencies": {
    "fast-check": "3.22.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
